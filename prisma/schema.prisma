generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TrainerRole {
  HEAD // главный тренер — видит отчёт и зарплаты всех
  TRAINER
}

model Trainer {
  id           String       @id @default(cuid())
  username     String       @unique
  passwordHash String
  role         TrainerRole  @default(TRAINER)
  displayName  String? // ФИО для отображения родителям — отдельно от логина (username)
  avatarUrl    String?
  bio          String?
  rank         AthleteRank? // личный разряд тренера по плаванию — тот же enum, что у спортсменов
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  attendanceRecords AttendanceRecord[]
  personalTrainings PersonalTraining[]
  groups            Group[] @relation("TrainerGroups")
}

enum GroupLevel {
  NOVICE // Новичок
  CONFIDENT // Уверенный пловец
  SPORT // Спортивный уровень
  TEAM // Сборная школы
}

model Group {
  id            String   @id @default(cuid())
  name          String
  level         GroupLevel
  daysOfWeek    String[] // напр. ["Пн", "Ср", "Пт"]
  time          String // напр. "17:00–17:45"
  pool          String
  capacity      Int? // максимальная вместимость; без ограничения, если не задана
  pricePerMonth Int? // тариф ₽/мес — для оценки выручки
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  children                 Child[]
  attendanceRecords        AttendanceRecord[]        @relation("SessionGroup")
  workoffCloses            AttendanceRecord[]        @relation("WorkoffClosesGroup")
  waitlist                 GroupWaitlist[]
  extraSessionEntitlements ExtraSessionEntitlement[]
  trainers                 Trainer[]                 @relation("TrainerGroups")
}

enum ChildStatus {
  ACTIVE
  SICK // "болеет" — пауза без пометки "потерянного" ученика
}

model Child {
  id           String      @id @default(cuid())
  lastName     String
  firstName    String
  groupId      String?
  group        Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parentPhone  String // хранится нормализованным (только цифры)
  paidUntil    DateTime?
  status       ChildStatus @default(ACTIVE)
  note         String? // заметка тренера (например при звонке "холодному" ребёнку)
  birthDate    DateTime?   @db.Date // дата рождения ребёнка (собирается при онлайн-записи)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  attendanceRecords        AttendanceRecord[]
  eventSignups             EventSignup[]
  personalTrainings        PersonalTraining[]
  paymentReceipts          PaymentReceipt[]
  medicalCertificates      MedicalCertificate[]
  competitionResults       CompetitionResult[]
  waitlistEntries          GroupWaitlist[]
  extraSessionEntitlements ExtraSessionEntitlement[]
  linkedAthlete            Athlete?

  @@index([groupId])
  @@index([parentPhone])
}

// Право ребёнка на доп. занятия в неделю в ЧУЖОЙ группе (помимо основной groupId) —
// фиксируется онлайн-записью для расчёта тарифа; фактическая отметка прихода на
// такое занятие идёт через AttendanceRecord.status = EXTRA (см. ниже), группа и
// уровень ребёнка при этом не меняются.
model ExtraSessionEntitlement {
  id              String   @id @default(cuid())
  childId         String
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessionsPerWeek Int
  createdAt       DateTime @default(now())

  @@unique([childId, groupId])
  @@index([groupId])
}

model GroupWaitlist {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([childId, groupId])
  @@index([groupId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  WORKOFF
  EXTRA // "Допзанятие" — ребёнок пришёл в чужую группу доп. занятием (не отработка)
}

model AttendanceRecord {
  id        String            @id @default(cuid())
  childId   String
  child     Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group             @relation("SessionGroup", fields: [groupId], references: [id], onDelete: Cascade)
  date      DateTime          @db.Date
  status    AttendanceStatus
  // Если status = WORKOFF: какая группа/пропуск "закрывается" этой отработкой (для истории, не участвует в подсчёте остатка)
  workoffClosesGroupId String?
  workoffClosesGroup    Group?  @relation("WorkoffClosesGroup", fields: [workoffClosesGroupId], references: [id], onDelete: SetNull)
  // Тренер, который поставил эту отметку — используется для расчёта зарплаты
  markedByTrainerId String
  markedByTrainer   Trainer  @relation(fields: [markedByTrainerId], references: [id])
  createdAt DateTime          @default(now())

  @@index([childId])
  @@index([groupId, date])
  @@index([markedByTrainerId, date])
  @@unique([childId, groupId, date])
}

enum PersonType {
  CHILD
  ADULT
}

model PersonalTraining {
  id         String     @id @default(cuid())
  trainerId  String
  trainer    Trainer    @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  date       DateTime   @db.Date
  time       String // напр. "18:00"
  personType PersonType
  childId    String?
  child      Child?     @relation(fields: [childId], references: [id], onDelete: SetNull)
  adultName  String? // ФИО взрослого, если personType = ADULT
  completed  Boolean    @default(true)
  createdAt  DateTime   @default(now())

  @@index([trainerId, date])
}

model PaymentReceipt {
  id               String    @id @default(cuid())
  childId          String
  child            Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  fileUrl          String
  contentType      String? // image/jpeg, image/png, application/pdf и т.д. — для выбора превью/иконки
  recognizedAmount Int? // сумма, распознанная OCR (если совпала с одним из тарифов)
  resolvedAt       DateTime? // когда тренер выбрал вариант продления по подсказке — прячет её
  createdAt        DateTime  @default(now())
  viewedAt         DateTime?

  @@index([childId])
}

model MedicalCertificate {
  id          String   @id @default(cuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  fileUrl     String
  contentType String?
  validUntil  DateTime @db.Date
  createdAt   DateTime @default(now())

  @@index([childId])
}

model CompetitionResult {
  id              String   @id @default(cuid())
  childId         String
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  competitionName String
  date            DateTime @db.Date
  result          String
  createdAt       DateTime @default(now())

  @@index([childId])
}

// Спортивный разряд — анкетное поле, заполняет сам спортсмен, тренер не подтверждает.
enum AthleteRank {
  YOUTH_3 // 3 юношеский
  YOUTH_2 // 2 юношеский
  YOUTH_1 // 1 юношеский
  ADULT_3 // 3 взрослый
  ADULT_2 // 2 взрослый
  ADULT_1 // 1 взрослый
  KMS
  MS
  MSMK
}

// Пол — анкетное поле, заполняет сам спортсмен (нужен для сопоставления
// личных рекордов с таблицей разрядов ЕВСК, где норматив у каждого разряда
// разный для М и Ж).
enum Gender {
  MALE
  FEMALE
}

// Спортсмен — полностью независимая от Child учётная запись: самостоятельная
// регистрация по фамилии+имени+дате рождения (дата = пароль), без связи с
// разделом "Дети"/группами/посещаемостью.
model Athlete {
  id            String       @id @default(cuid())
  lastName      String
  firstName     String
  birthDate     DateTime     @db.Date
  avatarUrl     String? // фото профиля, публичный URL в Vercel Blob
  level         GroupLevel? // те же 3 значения, что и у групп (Новичок/Уверенный/Спорт группа); назначает главный тренер
  rank          AthleteRank?
  gender        Gender?
  // Связь с обычным учеником ("Дети"), если это один и тот же реальный ребёнок —
  // определяется автоматически по совпадению ФИО+даты рождения при входе спортсмена
  // (см. athleteLoginAction), позволяет спортсмену видеть курсовку, внесённую тренером.
  linkedChildId String?      @unique
  linkedChild   Child?       @relation(fields: [linkedChildId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  poolWorkouts        PoolWorkout[]
  gymWorkouts         GymWorkout[]
  flexibilityWorkouts FlexibilityWorkout[]
  competitionResults  AthleteCompetitionResult[]
  levelTrainingLogs   LevelTrainingLog[]

  @@index([lastName, firstName])
}

enum StoryMediaType {
  PHOTO
  VIDEO
}

enum StoryAuthorRole {
  TRAINER
  ATHLETE
  PARENT
}

// "Истории" — фото/видео (одно на историю) + опциональная подпись, живут 24 часа
// (фильтр по createdAt при чтении, без отдельного expiresAt и без фоновой очистки —
// простой просмотр, без лайков/просмотров/комментариев). Удалить может автор или
// любой тренер (модерация). Единая модель для всех трёх ролей — authorId без FK,
// т.к. указывает то на Trainer.id, то на Athlete.id, то на Child.id (родитель
// привязан через ребёнка, как и остальные родительские данные в проекте — отдельной
// модели Parent нет). Видимость по ролям считается в src/lib/stories.ts, не в схеме.
model Story {
  id         String          @id @default(cuid())
  authorRole StoryAuthorRole
  authorId   String
  mediaUrl   String
  mediaType  StoryMediaType
  caption    String?
  createdAt  DateTime        @default(now())

  @@index([authorRole, authorId])
  @@index([createdAt])
}

// Задания по уровням для спортсменов (ОФП + Гибкость) — редактирует главный тренер
// на странице "Тренировки". Журнал по дням: одна запись на пару (уровень, дата) —
// history сохраняется, а не перезаписывается при добавлении нового дня.
model LevelTraining {
  id              String     @id @default(cuid())
  level           GroupLevel
  date            DateTime   @db.Date
  ofpTask         String
  flexibilityTask String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([level, date])
}

enum TrainingLogType {
  OFP
  FLEXIBILITY
}

// Архив отметок выполнения назначенных тренером заданий (ОФП/Гибкость) по уровню —
// отдельно от дневника (PoolWorkout/GymWorkout/FlexibilityWorkout), который спортсмен
// заполняет по факту тренировки. Хранится вечно, level — снимок на момент отметки,
// не ссылка (при смене уровня спортсмена история не должна "переписываться").
model LevelTrainingLog {
  id              String          @id @default(cuid())
  athleteId       String
  athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  level           GroupLevel
  type            TrainingLogType
  date            DateTime        @db.Date
  durationMinutes Int
  createdAt       DateTime        @default(now())

  @@index([athleteId])
}

model PoolWorkout {
  id           String   @id @default(cuid())
  athleteId    String
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  task         String // что проплыли, напр. "4×100 кроль"
  volumeMeters Int // объём за тренировку, метры
  feeling      String? // самочувствие — что болит/не болит, где было тяжело
  createdAt    DateTime @default(now())

  @@index([athleteId])
}

model GymWorkout {
  id              String   @id @default(cuid())
  athleteId       String
  athlete         Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  task            String
  durationMinutes Int
  createdAt       DateTime @default(now())

  @@index([athleteId])
}

model FlexibilityWorkout {
  id              String   @id @default(cuid())
  athleteId       String
  athlete         Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  task            String // что тянул, напр. "шпагат, плечи, спина"
  durationMinutes Int
  createdAt       DateTime @default(now())

  @@index([athleteId])
}

// Дисциплины плавания в ластах по классификации ЕВСК.
enum FinDiscipline {
  APNEA50 // 50 ныр.
  M50 // 50 м
  M100 // 100 м
  M200 // 200 м
  M400 // 400 м
  M800 // 800 м
  M1500 // 1500 м
  UNDERWATER100 // 100 п/п
  UNDERWATER400 // 400 п/п
  CLASSIC50 // 50 кл/п
  CLASSIC100 // 100 кл/п
  CLASSIC200 // 200 кл/п
  CLASSIC400 // 400 кл/п
}

enum TimingType {
  MANUAL // Ручной хронометраж
  AUTO // Автоматический хронометраж
}

// Результат заплыва на соревновании. Личный рекорд по связке дисциплина+хронометраж
// не хранится отдельным флагом — вычисляется на лету как минимальный
// resultCentis среди записей с одинаковыми discipline+timing (см. src/lib/athleteCompetitions.ts).
model AthleteCompetitionResult {
  id              String        @id @default(cuid())
  athleteId       String
  athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  competitionName String
  date            DateTime      @db.Date
  discipline      FinDiscipline
  timing          TimingType
  resultCentis    Int // время в сотых долях секунды — для надёжного сравнения/сортировки
  createdAt       DateTime      @default(now())

  @@index([athleteId])
}

// Справочная таблица нормативов ЕВСК 2023-24 по плаванию в ластах — заполняется
// один раз seed-скриптом (prisma/seedRankStandards.mjs), не редактируется через UI.
model RankStandard {
  id           String        @id @default(cuid())
  discipline   FinDiscipline
  timing       TimingType
  gender       Gender
  rank         AthleteRank
  centiseconds Int

  @@unique([discipline, timing, gender, rank])
}

enum EventType {
  NEWS
  GATHERING
  COMPETITION
}

model Event {
  id          String    @id @default(cuid())
  title       String
  type        EventType
  dateStart   DateTime
  dateEnd     DateTime?
  location    String
  description String
  suitableFor String // напр. "8-10 лет, Уверенный пловец"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  signups EventSignup[]
}

model EventSignup {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, childId])
}
