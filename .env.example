DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Секрет для подписи JWT-сессий (сгенерировать случайную строку не короче 32 символов)
JWT_SECRET="change-me"

# Начальный аккаунт тренера (используется сид-скриптом)
TRAINER_USERNAME="trainer"
TRAINER_INITIAL_PASSWORD="change-me"

# Токен Vercel Blob (Storage → Create Blob Store → Connect to Project — токен появится сам)
BLOB_READ_WRITE_TOKEN="change-me"
